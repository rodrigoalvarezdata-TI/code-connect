# Copie para `.env` na raiz (já está no .gitignore) e ajuste o que precisar.
# O docker-compose.yml e a API leem daqui.

POSTGRES_USER=code_conect
POSTGRES_PASSWORD=code_conect
POSTGRES_DB=code_conect
POSTGRES_PORT=5432

# Host visto pela API. Rodando a API no host (pnpm api:dev) é localhost;
# se um dia a API virar um serviço do compose, passa a ser `postgres`.
POSTGRES_HOST=localhost

# Obrigatório em produção — `main.ts` recusa subir sem ele.
# JWT_SECRET=
